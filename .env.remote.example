# Remote checkout config example.
# Copy this file to the remote checkout as .env, then edit paths for that server.
# Example:
#   scp .env.remote.example wangqiao@47.94.108.140:/data/wangqiao/comfy-shell/.env
#
# This file is a template only. Local scripts do not read it automatically.

COMFY_PROFILE=server-cuda-a10
COMFY_ENV_BACKEND=uv
COMFY_PYTHON=3.12.13
COMFY_DEVICE=cuda
COMFY_HOST=127.0.0.1
COMFY_PORT=8188
CUDA_VISIBLE_DEVICES=0
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
HF_ENDPOINT=https://hf-mirror.com
COMFY_MODEL_ROOT=/data/wangqiao/ComfyUI/models
COMFY_OUTPUT_ROOT=/data/wangqiao/ComfyUI/output
