# Local comfy-shell config example.
# Copy once: cp .env.example .env
# Normal commands read .env; do not use .env.example as a runtime profile.
# COMFY_* paths in this file are for the current machine.

COMFY_PROFILE=macos-mps
COMFY_ENV_BACKEND=uv
COMFY_PYTHON=3.12.13
COMFY_DEVICE=mps
COMFY_HOST=127.0.0.1
COMFY_PORT=8188
TORCH_PRE=true
TORCH_INDEX_URL=https://download.pytorch.org/whl/nightly/cpu
HF_ENDPOINT=https://hf-mirror.com
COMFY_MODEL_ROOT=./ComfyUI/models
COMFY_OUTPUT_ROOT=./ComfyUI/output

# For Linux NVIDIA CUDA local runs, use values like:
# COMFY_PROFILE=server-cuda-a10
# COMFY_DEVICE=cuda
# CUDA_VISIBLE_DEVICES=0
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124

# Remote development defaults used when running scripts/remote.sh from this checkout.
REMOTE_HOST=wangqiao@47.94.108.140
REMOTE_DIR=/data/wangqiao/comfy-shell
REMOTE_READY_URL=http://127.0.0.1:8188
REMOTE_TUNNEL_LOCAL_PORT=8188
REMOTE_TUNNEL_REMOTE_HOST=127.0.0.1
REMOTE_TUNNEL_REMOTE_PORT=8188
REMOTE_LOG_TAIL=200
REMOTE_GPU_CONNECT_TIMEOUT=10
